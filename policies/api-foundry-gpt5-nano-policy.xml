<!--
  api-foundry-gpt5-nano-policy.xml  -  API scope (foundry-gpt5-nano-api).

  Responsibilities:
    1. <base /> first => inherits the GLOBAL foundry token-quota / burst policy.
    2. Force streaming usage metadata (stream_options.include_usage=true) so token
       accounting works for stream:true requests where supported.
    3. Route to the model-family backend POOL (priority failover + circuit breaker).
    4. Authenticate to Azure OpenAI data plane with APIM's managed identity
       (no keys stored in config/policy).

  References (Microsoft Learn):
    * set-backend-service:            https://learn.microsoft.com/azure/api-management/set-backend-service-policy
    * authentication-managed-identity: https://learn.microsoft.com/azure/api-management/authentication-managed-identity-policy
    * backends / pools / breaker:     https://learn.microsoft.com/azure/api-management/backends
-->
<policies>
  <inbound>
    <base />
    <!-- (1) Per-key token governance: shared lifetime/burst budget via counter-key.
         Header attributes are valid here (API scope) but not at global/product scope. -->
    <llm-token-limit
      counter-key="@(context.Subscription.Id)"
      tokens-per-minute="{{TPM_GUARDRAIL}}"
      token-quota="{{TOKEN_QUOTA}}"
      token-quota-period="{{TOKEN_QUOTA_PERIOD}}"
      estimate-prompt-tokens="false"
      tokens-consumed-header-name="x-tokens-consumed"
      remaining-tokens-header-name="x-tokens-remaining-minute"
      remaining-quota-tokens-header-name="x-tokens-remaining-quota"
      retry-after-header-name="x-retry-after" />
    <!-- (2) Force usage metadata for streaming requests so tokens can be accounted. -->
    <set-variable name="reqBody" value="@(context.Request.Body.As<JObject>(preserveContent: true))" />
    <choose>
      <when condition="@(((JObject)context.Variables["reqBody"])["stream"] != null && (bool)((JObject)context.Variables["reqBody"])["stream"])">
        <set-body>@{
          var body = (JObject)context.Variables["reqBody"];
          var so = body["stream_options"] as JObject ?? new JObject();
          so["include_usage"] = true;
          body["stream_options"] = so;
          return body.ToString();
        }</set-body>
      </when>
      <otherwise />
    </choose>
    <!-- (3) Route to the regional backend pool for this model family. -->
    <set-backend-service backend-id="pool-foundry-gpt5-nano" />
    <!-- (4) Mint an Entra token for Azure OpenAI and present it as a bearer token. -->
    <authentication-managed-identity resource="https://cognitiveservices.azure.com" output-token-variable-name="msi-access-token" ignore-error="false" />
    <set-header name="Authorization" exists-action="override">
      <value>@("Bearer " + (string)context.Variables["msi-access-token"])</value>
    </set-header>
    <!-- Strip the inbound api-key header so it never reaches the backend. -->
    <set-header name="api-key" exists-action="delete" />
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
