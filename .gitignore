**/*.bicep.json

# Local env / secrets (never commit keys or exported subscription secrets)
*.env
*.key
*.secret
**/secrets*.json
**/keys*.json
**/*subscription-keys*.json

# Logs and local output
*.log
*.tmp

# OS / editor
.DS_Store
Thumbs.db
.vscode/
